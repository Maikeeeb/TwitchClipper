<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorBackground">#FFF7F7F9</Color>
    <Color x:Key="ColorSurface">#FFFFFFFF</Color>
    <Color x:Key="ColorPrimary">#FF1F6FEB</Color>
    <Color x:Key="ColorText">#FF1E1E1E</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorText}" />

    <Style TargetType="Button">
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinHeight" Value="30" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
</ResourceDictionary>
