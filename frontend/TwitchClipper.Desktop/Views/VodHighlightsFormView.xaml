<UserControl x:Class="TwitchClipper.Desktop.Views.VodHighlightsFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.ColumnSpan="2"
                       Text="SCR-002 New VOD Highlights Job"
                       FontSize="24"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="1" Text="VOD URL or local path" Margin="0,8,8,8" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VodUrl, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP001" />

            <TextBlock Grid.Row="2" Text="Output directory" Margin="0,8,8,8" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP002" />

            <TextBlock Grid.Row="3" Text="Chat path (optional)" Margin="0,8,8,8" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ChatPath, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP003" />

            <TextBlock Grid.Row="4" Text="Keywords (comma-separated)" Margin="0,8,8,8" />
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding KeywordsText, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP004" />

            <TextBlock Grid.Row="5" Text="Min count" Margin="0,8,8,8" />
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding MinCount, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP005" />

            <TextBlock Grid.Row="6" Text="Spike window seconds" Margin="0,8,8,8" />
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SpikeWindowSeconds, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP006" />

            <TextBlock Grid.Row="7" Text="Segment padding seconds" Margin="0,8,8,8" />
            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SegmentPaddingSeconds, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP007" />

            <TextBlock Grid.Row="8" Text="Max segment seconds" Margin="0,8,8,8" />
            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding MaxSegmentSeconds, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP008" />

            <TextBlock Grid.Row="9" Text="Diversity windows" Margin="0,8,8,8" />
            <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding DiversityWindows, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="SCR002-CMP009" />

            <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Foreground="DarkRed" Text="{Binding FormAlert}" TextWrapping="Wrap" />

            <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Margin="0,16,0,0" Orientation="Horizontal">
                <Button Content="Submit VOD Highlights Job" Command="{Binding SubmitCommand}" Margin="0,0,8,0" AutomationProperties.Name="SCR002-CMP010" />
                <Button Content="Reset defaults" Command="{Binding ResetDefaultsCommand}" Margin="0,0,8,0" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" AutomationProperties.Name="SCR002-CMP011" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
