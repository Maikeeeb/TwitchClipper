<UserControl x:Class="TwitchClipper.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="SCR-001 Dashboard"
                   FontSize="24"
                   FontWeight="SemiBold"
                   AutomationProperties.Name="Dashboard heading" />

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,12"
                    Orientation="Vertical">
            <TextBlock Text="{Binding HealthSummary}" />
            <TextBlock Text="{Binding WorkerSummary}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding RecentJobs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  MinHeight="260"
                  AutomationProperties.Name="Recent jobs table">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Job ID" Binding="{Binding Id}" Width="2*" />
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                <DataGridTextColumn Header="Progress" Binding="{Binding Progress}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
