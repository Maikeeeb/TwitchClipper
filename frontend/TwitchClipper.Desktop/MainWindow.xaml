<Window x:Class="TwitchClipper.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:TwitchClipper.Desktop.ViewModels"
        xmlns:views="clr-namespace:TwitchClipper.Desktop.Views"
        Title="TwitchClipper Desktop"
        Height="900"
        Width="1400"
        MinHeight="800"
        MinWidth="1280"
        Background="{StaticResource BackgroundBrush}">
    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding NavigateToDashboardCommand}" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding NavigateToVodCommand}" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding NavigateToClipCommand}" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{Binding NavigateToJobsCommand}" />
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding SubmitCurrentFormCommand}" />
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding RefreshCurrentScreenCommand}" />
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding BackCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCurrentActionCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:VodHighlightsFormViewModel}">
            <views:VodHighlightsFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ClipMontageFormViewModel}">
            <views:ClipMontageFormView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:JobsQueueViewModel}">
            <views:JobsQueueView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:JobDetailViewModel}">
            <views:JobDetailView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2"
                Padding="10"
                Background="#FFFFF4CE"
                Visibility="{Binding IsOnline, Converter={StaticResource InverseBoolToVisibility}}">
            <TextBlock Text="{Binding ConnectionBanner}" FontWeight="SemiBold" />
        </Border>

        <StackPanel Grid.Row="1" Margin="0,10,10,0">
            <TextBlock Text="TwitchClipper" FontSize="20" FontWeight="SemiBold" Margin="4" />
            <Button Content="Dashboard (Ctrl+1)" Command="{Binding NavigateToDashboardCommand}" />
            <Button Content="New VOD (Ctrl+2)" Command="{Binding NavigateToVodCommand}" />
            <Button Content="New Clip (Ctrl+3)" Command="{Binding NavigateToClipCommand}" />
            <Button Content="Jobs (Ctrl+4)" Command="{Binding NavigateToJobsCommand}" />
            <Button Content="Back (Alt+Left)" Command="{Binding BackCommand}" Margin="0,12,0,0" />
            <Button Content="Refresh (Ctrl+R)" Command="{Binding RefreshCurrentScreenCommand}" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Background="{StaticResource SurfaceBrush}">
            <ContentControl Content="{Binding CurrentScreenViewModel}" />
        </Border>
    </Grid>
</Window>
